# Required for the router (LLM call 1) and synthesizer (LLM call 2).
OPENAI_API_KEY=

# Optional: point at any OpenAI-compatible endpoint (Azure OpenAI, a local
# model server like Ollama/vLLM, a proxy, etc.). Leave blank to use OpenAI.
# Examples:
#   OPENAI_BASE_URL=https://my-proxy.example.com/v1
#   OPENAI_BASE_URL=http://localhost:11434/v1   # Ollama
OPENAI_BASE_URL=

# Required.
PORT=3000
ROUTER_MODEL=gpt-4o-mini
SYNTH_MODEL=gpt-4o-mini
